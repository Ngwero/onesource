# Shop auth (Supabase → Project Settings → API → anon public key)
# Required for Railway build (Vite embeds these at build time).
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key

# Not needed on Railway (shop and API share one domain). Only for split hosting:
# VITE_API_URL=https://your-api-host.com/api
