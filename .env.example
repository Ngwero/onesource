# Optional — only needed when the API is not on the same origin (e.g. production build).
# Dev uses Vite proxy: /api → http://localhost:3001
# VITE_API_URL=http://localhost:3001/api

# Shop auth (Supabase → Project Settings → API → anon public key)
VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-public-key
