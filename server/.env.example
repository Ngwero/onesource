# Copy to .env:  cp .env.example .env
# Validate:      npm run check:env
#
# Supabase → Project Settings → API (use the service role key, not the anon key)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Shop frontend (project root .env — use the anon public key, NOT the service role key)
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your-anon-public-key

PORT=3001

# Shop URL used in password-reset emails (logo links, footer, redirect fallback)
# On Railway, SHOP_URL is optional — https://RAILWAY_PUBLIC_DOMAIN is used automatically
SHOP_URL=http://localhost:5174

# SMTP — password reset emails are sent from the API (not Supabase default mailer)
# Examples: Gmail (smtp.gmail.com:587), SendGrid, Mailgun, Brevo, Amazon SES
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password-or-app-password
SMTP_FROM="One Source <noreply@yourdomain.com>"

# Uploads: saved as WebP — when Supabase is configured, uploads go to Storage automatically (live on shop + Railway).
# Set USE_SUPABASE_STORAGE=false only for offline local-only dev without cloud.
USE_SUPABASE_STORAGE=true
# SUPABASE_STORAGE_BUCKET=images
