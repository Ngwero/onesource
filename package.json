{
  "name": "amazon-uk-clone",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:server": "npm run dev --prefix server",
    "dev:all": "npm run dev:server & npm run dev",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "seed": "npm run seed --prefix server",
    "seed:bulk": "npm run seed:bulk --prefix server",
    "check:env": "npm run check:env --prefix server",
    "i18n:terms": "node scripts/generate-product-terms.mjs",
    "i18n:build": "node scripts/generate-product-terms.mjs && node scripts/build-locales.mjs"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.106.1",
    "i18next": "^26.2.0",
    "lottie-react": "^2.4.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.15.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^24.12.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "tailwindcss": "^4.3.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
